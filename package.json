{
    "name": "bridge-app",
    "version": "1.1.5",
    "author": "Paweł Rak",
    "private": true,
    "main": "electron/main.js",
    "scripts": {
        "next:dev": "next dev -p 3010",
        "next:build": "next build --webpack",
        "next:start": "next start -p 3010",
        "electron:dev": "concurrently \"next dev -p 3010 -H 127.0.0.1\" \"wait-on http://127.0.0.1:3010 && cross-env NODE_ENV=development PORT=3010 node scripts/start-electron.js\"",
        "electron:build": "node -e \"require('fs').rmSync('.next', {recursive:true, force:true})\" && npm run next:build && node scripts/fix-standalone.js && electron-builder",
        "dev": "npm run electron:dev",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "eslint",
        "test": "vitest run"
    },
    "dependencies": {
        "@capacitor/android": "^8.1.0",
        "@capacitor/camera": "^8.0.2",
        "@capacitor/cli": "^8.1.0",
        "@capacitor/core": "^8.1.0",
        "@capacitor/filesystem": "^8.1.2",
        "@capacitor/haptics": "^8.0.1",
        "@capacitor/share": "^8.0.1",
        "@capacitor/toast": "^8.0.1",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.5.0",
        "@types/archiver": "^7.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/jszip": "^3.4.0",
        "@types/nodemailer": "^7.0.9",
        "@types/react-virtualized-auto-sizer": "^1.0.4",
        "@types/react-window": "^1.8.8",
        "@types/three": "^0.182.0",
        "@types/uuid": "^10.0.0",
        "archiver": "^7.0.1",
        "bcryptjs": "^3.0.3",
        "chokidar": "^5.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "fs-extra": "^11.3.4",
        "glob": "^13.0.6",
        "jose": "^6.1.3",
        "jsonwebtoken": "^9.0.3",
        "jszip": "^3.10.1",
        "libsodium-wrappers": "^0.8.2",
        "lucide-react": "^0.563.0",
        "lz4js": "^0.2.0",
        "mongoose": "^9.2.2",
        "next": "16.1.6",
        "nodemailer": "^8.0.1",
        "ollama": "^0.6.3",
        "peer": "^1.0.2",
        "peerjs": "^1.5.5",
        "pg": "^8.18.0",
        "pocketbase": "^0.26.8",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hot-toast": "^2.6.0",
        "react-intersection-observer": "^10.0.3",
        "react-virtualized-auto-sizer": "^2.0.2",
        "react-window": "^2.2.6",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "three": "^0.182.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@prisma/client": "^5.10.0",
        "@tailwindcss/postcss": "^4",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.19.37",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.2.1",
        "electron-builder": "^26.7.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "nodemon": "^3.1.14",
        "prisma": "5.10.0",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^4.0.18",
        "wait-on": "^9.0.3"
    },
    "build": {
        "appId": "pl.virtuarch.3dbridge",
        "productName": "3D Bridge",
        "copyright": "Copyright © 2025 Paweł Rak / VirtuArch Software",
        "directories": {
            "buildResources": "build",
            "output": "dist"
        },
        "asar": true,
        "asarUnpack": [
            "node_modules",
            "**/.next/standalone",
            "**/.next/standalone/**/*",
            "electron"
        ],
        "files": [
            "electron/**/*",
            "Loader/**/*",
            ".next/standalone/**/*",
            "package.json",
            "node_modules/**/*",
            "!node_modules/.cache",
            "!**/*.{md,log,txt}",
            "!**/test*",
            "!**/scripts/**",
            "!scripts/generate-licenses.js",
            "!**/generate-licenses.js",
            "!**/prisma/**",
            "!**/.git/**"
        ],
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico",
            "artifactName": "3dBridge_1.0b.${ext}"
        },
        "fileAssociations": [
            {
                "ext": "asset",
                "name": "3D Bridge Asset",
                "description": "Encrypted 3DBridge geometry package",
                "role": "Viewer"
            },
            {
                "ext": [
                    "obj",
                    "fbx",
                    "glb",
                    "gltf"
                ],
                "name": "3D Model File",
                "role": "Viewer"
            }
        ],
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerSidebar": "build/installerSidebar.bmp",
            "uninstallerSidebar": "build/installerSidebar.bmp",
            "installerHeader": "build/installerHeader.bmp",
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "installerHeaderIcon": "build/icon.ico",
            "createDesktopShortcut": "always",
            "createStartMenuShortcut": true,
            "shortcutName": "3D Bridge",
            "runAfterFinish": true,
            "deleteAppDataOnUninstall": false,
            "include": "build/installer.nsh",
            "unicode": true,
            "perMachine": false,
            "allowElevation": true,
            "displayLanguageSelector": false,
            "installerLanguages": [
                "en_US",
                "pl_PL"
            ],
            "language": "1033"
        }
    }
}
